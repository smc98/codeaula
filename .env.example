# Configuración de puertos de Codeaula.
#
# Para usarlo: copia este fichero a ".env" en la misma carpeta
# (junto a docker-compose.yml) y ajusta los valores si lo necesitas.
#
#   cp .env.example .env
#
# Si no creas el fichero ".env", se usan los valores por defecto que
# aparecen aquí (8000 y 5173), así que esto es completamente opcional.

# Puerto del backend (Django). Los alumnos no acceden a este directamente;
# solo se usa internamente y para depuración/admin del profesor.
BACKEND_PORT=8000

# Puerto del frontend (lo que abren los alumnos en el navegador).
# Cámbialo a 80 si quieres que los alumnos accedan sin especificar puerto
# (http://<IP-del-profesor> en vez de http://<IP-del-profesor>:5173).
# Nota: en Windows/Mac/Linux, usar el puerto 80 puede requerir permisos de
# administrador si hay otro servicio (IIS, Apache, Skype...) ocupándolo ya.
# Si el arranque falla, prueba con otro puerto, p.ej. 8080.
FRONTEND_PORT=5173
