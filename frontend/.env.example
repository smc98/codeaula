# Copia este fichero a .env.local para desarrollo local SIN Docker:
#   cp .env.example .env.local
#
# Con Docker Compose NO hace falta tocar esto: el frontend usa rutas
# relativas por defecto (ver src/api/codeaula.js) y el proxy de Vite las
# redirige al backend dentro de la red de contenedores. Esto es lo que
# permite que tanto el profesor (localhost) como cada alumno (IP local del
# profesor en el aula) accedan correctamente sin configurar nada.
#
# Estas variables solo son necesarias si arrancas el frontend SUELTO con
# `npm run dev` fuera de Docker, apuntando a un backend en otra URL/puerto.

VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
